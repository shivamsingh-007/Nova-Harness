{
  "decision_id": "string (required, non-blank)",
  "budget_id": "string (required, non-blank)",
  "overrun_disposition": "reallocate | require_approval | adjust_scope | stop_execution | ignore_override",
  "decision_reason": "string (required, non-blank)",
  "approved_by": "string | null",
  "reallocated_from_budget_id": "string | null (required if disposition = reallocate)",
  "additional_amount": "float >= 0 | null",
  "effective_from": "ISO 8601 timestamp",
  "effective_until": "ISO 8601 timestamp | null"
}
