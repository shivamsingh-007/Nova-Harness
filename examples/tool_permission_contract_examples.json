    {
      "label": "high_risk_delete_action_requiring_approval",
      "description": "Critical-risk delete action that requires explicit approval before execution",
      "tool_descriptor": {
        "tool_id": "td-storage",
        "tool_name": "object_store",
        "version": "1.5.0",
        "description": "Cloud object storage management",
        "supported_actions": ["read", "write", "delete"],
        "risk_level": "critical"
      },
      "execution_constraint": {
        "timeout_seconds": 60,
        "network_access": "full",
        "filesystem_access": "none",
        "allowed_paths": []
      },
      "capability_grant": {
        "grant_id": "g-storage-admin",
        "agent_id": "agent-admin",
        "tool_id": "td-storage",
        "allowed_actions": ["read", "write", "delete"],
        "approval_requirement": "required",
        "credential_mode": "prebound_reference",
        "resource_scopes": ["storage:production", "storage:backup"],
        "execution_constraint": {
          "timeout_seconds": 60,
          "network_access": "full",
          "filesystem_access": "none",
          "allowed_paths": []
        }
      },
      "invocation_request": {
        "request_id": "req-delete-001",
        "run_id": "run-g7h8i9",
        "agent_id": "agent-admin",
        "tool_id": "td-storage",
        "action": "delete",
        "resource_target": "blob://containers/backup-2025-01",
        "tenant_id": "tenant-acme",
        "justification": "Remove expired backup per 90-day retention policy (ticket INFRA-442)"
      },
      "permission_decision": {
        "decision_id": "dec-delete-001",
        "request_id": "req-delete-001",
        "allowed": true,
        "reason": "DELETE on object_store granted by g-storage-admin but approval is required",
        "matched_grant_id": "g-storage-admin",
        "approval_required": true
      }
    },
