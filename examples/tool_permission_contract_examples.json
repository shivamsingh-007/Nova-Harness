  "examples": [
    {
      "label": "read_only_search_tool_grant",
      "description": "Read-only search tool with restricted network, no filesystem access",
      "tool_descriptor": {
        "tool_id": "td-search",
        "tool_name": "search_index",
        "version": "2.1.0",
        "description": "Read-only full-text search index",
        "supported_actions": ["read"],
        "risk_level": "low"
      },
      "execution_constraint": {
        "timeout_seconds": 30,
        "max_calls_per_run": 200,
        "network_access": "restricted",
        "filesystem_access": "none",
        "allowed_paths": []
      },
      "capability_grant": {
        "grant_id": "g-search-reader",
        "agent_id": "agent-reader",
        "tool_id": "td-search",
        "allowed_actions": ["read"],
        "approval_requirement": "none",
        "credential_mode": "scoped_ephemeral",
        "resource_scopes": ["index:docs", "index:knowledge_base"],
        "execution_constraint": {
          "timeout_seconds": 30,
          "max_calls_per_run": 200,
          "network_access": "restricted",
          "filesystem_access": "none",
          "allowed_paths": []
        }
      },
      "invocation_request": {
        "request_id": "req-search-001",
        "run_id": "run-a1b2c3",
        "agent_id": "agent-reader",
        "tool_id": "td-search",
        "action": "read",
        "resource_target": "index://docs/architecture",
        "tenant_id": "tenant-acme",
        "justification": "Retrieve architecture documentation for context assembly"
      },
      "permission_decision": {
        "decision_id": "dec-search-001",
        "request_id": "req-search-001",
        "allowed": true,
        "reason": "READ on search_index granted by g-search-reader with matching scope",
        "matched_grant_id": "g-search-reader",
        "approval_required": false
      }
    },
    {
