          "declaration_id": "dec-task-005",
          "party_ref": "task-optimizer",
          "party_type": "task",
          "capability_category": "model_behavior"
        },
        "offer_declaration": {
          "declaration_id": "dec-model-005",
          "party_ref": "model-lite",
          "party_type": "model",
          "capability_category": "model_behavior"
        },
        "evaluation": {
          "evaluation_id": "eval-override",
          "request_declaration_id": "dec-task-005",
          "offer_declaration_id": "dec-model-005",
          "compatibility_status": "partially_compatible",
          "matched_requirement_ids": ["req-basic-reasoning"],
          "unmatched_requirement_ids": ["req-advanced-reasoning"],
          "score": 50.0
