          "party_type": "tool",
          "capability_category": "tooling"
        },
        "evaluation": {
          "evaluation_id": "eval-incomp",
          "request_declaration_id": "dec-task-003",
          "offer_declaration_id": "dec-tool-003",
          "compatibility_status": "incompatible",
          "unmatched_requirement_ids": ["req-transactional"],
          "score": 0.0
