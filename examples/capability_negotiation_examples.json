{
  "description": "P62 Capability Negotiation & Compatibility Contract examples — full compatibility, partial with fallback, hard incompatibility, session-effective subset, and manual override.",
  "examples": [
    {
      "name": "full_compatibility_between_task_and_role",
      "description": "A task and a role have fully compatible capabilities. The evaluation scores 100% and the decision is proceed.",
      "envelope": {
        "envelope_id": "env-full",
        "request_declaration": {
          "declaration_id": "dec-task-001",
          "party_ref": "task-analysis",
          "party_type": "task",
          "capability_category": "tooling",
          "schema_version": "1.0"
        },
        "offer_declaration": {
          "declaration_id": "dec-role-001",
          "party_ref": "role-analyst",
          "party_type": "role",
          "capability_category": "tooling"
        },
        "evaluation": {
          "evaluation_id": "eval-full",
          "request_declaration_id": "dec-task-001",
          "offer_declaration_id": "dec-role-001",
          "compatibility_status": "compatible",
          "matched_requirement_ids": ["req-analysis-tool"],
          "score": 100.0
        },
        "negotiated_set": {
          "negotiated_set_id": "nset-full",
          "evaluation_id": "eval-full",
          "negotiation_mode": "strict_intersection",
          "negotiated_capabilities": ["data_analysis", "charting"],
          "required_satisfied": ["req-analysis-tool"]
        },
        "decision": {
          "decision_id": "nd-full",
          "evaluation_id": "eval-full",
          "negotiated_set_id": "nset-full",
          "negotiation_disposition": "proceed"
        }
      }
    },
    {
      "name": "partial_compatibility_with_fallback_output_format",
      "description": "A task requires CSV and HTML output. The tool only supports CSV. A partial match with fallback to CSV-only is decided.",
      "envelope": {
        "envelope_id": "env-partial",
        "request_declaration": {
          "declaration_id": "dec-task-002",
          "party_ref": "task-data-pipeline",
          "party_type": "task",
          "capability_category": "output_format"
        },
        "offer_declaration": {
          "declaration_id": "dec-tool-002",
          "party_ref": "tool-renderer",
          "party_type": "tool",
          "capability_category": "output_format"
        },
        "evaluation": {
          "evaluation_id": "eval-partial",
          "request_declaration_id": "dec-task-002",
          "offer_declaration_id": "dec-tool-002",
          "compatibility_status": "partially_compatible",
          "matched_requirement_ids": ["req-csv"],
          "unmatched_requirement_ids": ["req-html"],
          "score": 60.0
        },
        "gaps": [
          {
            "gap_id": "gap-partial",
            "evaluation_id": "eval-partial",
            "capability_name": "html_output",
            "gap_summary": "Tool does not support HTML output",
            "blocking": false,
            "fallback_options": ["csv_only", "markdown"]
          }
        ],
        "decision": {
          "decision_id": "nd-partial",
          "evaluation_id": "eval-partial",
          "negotiation_disposition": "proceed_with_fallbacks",
          "decision_reason": "HTML not supported, falling back to CSV",
          "selected_fallbacks": ["csv_only"]
        }
      }
    },
    {
      "name": "incompatible_tool_rejected",
