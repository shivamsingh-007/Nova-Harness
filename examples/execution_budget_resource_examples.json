    {
      "name": "branch_level_reallocation_from_parent_budget",
      "description": "A branch budget exceeds its token allocation, and a reallocation decision pulls additional tokens from the parent run-level budget.",
      "envelope": {
        "envelope_id": "env-budget-realloc",
        "budget": {
          "budget_id": "budget-branch",
          "scope_type": "branch",
          "scope_ref": "branch-003",
          "parent_budget_id": "budget-parent",
          "budget_status": "overrun",
          "created_at": "2026-07-05T10:00:00Z",
          "updated_at": "2026-07-05T10:05:00Z"
        },
        "budget_lines": [
          {
            "budget_line_id": "bl-branch-tokens",
            "budget_id": "budget-branch",
            "resource_type": "tokens",
            "allocated_amount": 20000.0,
            "reserved_amount": 5000.0,
            "consumed_amount": 18000.0,
            "remaining_amount": -3000.0,
            "unit": "tokens"
          }
        ],
        "decisions": [
          {
            "decision_id": "dec-realloc",
            "budget_id": "budget-branch",
            "overrun_disposition": "reallocate",
            "decision_reason": "Branch exceeded token budget, reallocating from parent",
            "approved_by": "manager-alpha",
            "reallocated_from_budget_id": "budget-parent",
            "additional_amount": 5000.0,
            "effective_from": "2026-07-05T10:05:00Z"
          }
        ]
      }
    },
    {
      "name": "hard_threshold_stop_execution",
      "description": "A hard threshold policy is configured at 100% usage. When consumed hits the allocated amount, the action is stop_execution.",
