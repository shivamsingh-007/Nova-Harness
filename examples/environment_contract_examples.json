[
  {
    "title": "Local development profile",
    "description": "A local development profile with default values, optional log level, and env-var-based secrets",
    "envelope": {
      "envelope_id": "env-local-dev",
      "bundle": {
        "bundle_id": "bundle-local",
        "profile": {
          "environment": "local",
          "profile_id": "prof-local",
          "name": "Local Development",
          "description": "Local development environment with relaxed defaults",
          "config_keys": [
            { "key": "db_host", "scope": "global", "source": "env_var", "required": true, "description": "Database hostname" },
            { "key": "db_port", "scope": "global", "source": "default", "required": false, "description": "Database port" },
            { "key": "log_level", "scope": "global", "source": "default", "required": false, "description": "Logging verbosity" }
          ],
          "secrets": [
            { "secret_id": "sec-001", "name": "db_password", "storage_type": "env_var", "required": true, "source_hint": "LOCAL_DB_PASSWORD" }
          ],
          "runtime_settings": [
            { "setting_id": "s-001", "key_ref": { "key": "db_host", "scope": "global", "source": "env_var" }, "value_type": "string", "sensitive": false },
            { "setting_id": "s-002", "key_ref": { "key": "db_port", "scope": "global", "source": "default" }, "value_type": "integer", "default_value": "5432", "sensitive": false },
            { "setting_id": "s-003", "key_ref": { "key": "log_level", "scope": "global", "source": "default" }, "value_type": "string", "default_value": "debug", "sensitive": false }
          ]
        },
        "values": { "db_host": "localhost", "db_port": "5432", "log_level": "debug" }
      },
      "secrets_manifest": {
        "manifest_id": "manifest-local",
        "profile_id": "prof-local",
        "secrets": [
          { "secret_id": "sec-001", "name": "db_password", "storage_type": "env_var", "required": true, "source_hint": "LOCAL_DB_PASSWORD" }
        ]
      }
    }
  },
  {
