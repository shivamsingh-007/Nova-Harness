        "retryable": true,
        "user_safe": false,
        "recovery_disposition": "retryable",
        "context": {
          "run_id": "run-999",
          "trace_id": "trace-jkl-012",
          "step_id": "step-final",
          "operation": "persist_run_state",
          "component": "state_writer"
        },
        "details": [
          "target_path=/var/harness/runs/run-999.json",
          "error=no space left on device",
          "fs_usage=100%"
