    {
      "name": "reusable_dod_profile_for_code_tasks",
      "description": "A reusable definition-of-done profile defining quality, verification, documentation, and release gates for all code changes.",
      "definition_of_done_profile": {
        "dod_profile_id": "dod-code",
        "name": "Standard Code DoD",
        "description": "Baseline quality gates for all code changes",
