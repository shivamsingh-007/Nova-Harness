          {
            "done_check_id": "dod-docs",
            "done_check_type": "documentation_gate",
            "description": "Documentation updated",
            "required": false,
            "validation_method": "doc review",
            "status": "passed",
            "applies_to_task_types": ["implementation", "feature"]
          },
          {
            "done_check_id": "dod-release",
            "done_check_type": "release_gate",
            "description": "Release checklist complete",
            "required": true,
            "validation_method": "release_ticket",
            "status": "passed",
            "applies_to_task_types": []
          }
        ],
        "version": "2.0",
        "owner": "eng-team",
        "active": true
      }
    },
