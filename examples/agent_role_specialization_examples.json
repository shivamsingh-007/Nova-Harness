{
  "description": "P50 Agent Role & Specialization Contract examples — role definitions, capability boundaries, assignment records, and validation rejections.",
  "examples": [
    {
      "name": "manager_role_with_supervisory_autonomy",
      "description": "Manager role with supervisory autonomy, delegation capabilities, and coordination specialization.",
      "envelope": {
        "envelope_id": "env-mgr-001",
        "role_definition": {
          "role_id": "role-mgr-001",
          "role_type": "manager",
          "name": "Team Manager",
          "description": "Coordinates multi-agent workflows, delegates tasks, and reviews outcomes",
          "status": "active",
          "specialization_type": "coordination_specific",
          "autonomy_level": "supervisory",
          "expected_output_types": ["plan", "review"],
          "owner": "platform-team",
          "version": "2.0.0"
        },
        "specialization_profile": {
          "profile_id": "spec-mgr-001",
          "role_id": "role-mgr-001",
          "domain_tags": ["multi-agent", "orchestration"],
          "task_types": ["task decomposition", "delegation", "progress tracking"],
          "strengths": ["breaking down complex tasks", "parallel coordination"],
          "weaknesses": ["not optimized for detailed execution"],
          "preferred_problem_shapes": ["multi-step workflows", "parallel subtasks"],
          "avoid_problem_shapes": ["single-step code generation"],
          "quality_focus": "completeness and coherence",
          "risk_notes": "May over-delegate without sufficient context sharing"
        },
        "capability_profile": {
          "capability_profile_id": "cap-mgr-001",
          "role_id": "role-mgr-001",
          "allowed_tools": ["read", "write", "delegate", "review"],
          "allowed_skill_ids": ["skill-delegation", "skill-review"],
          "allowed_model_classes": ["gpt-4", "claude-3"],
          "allowed_context_types": ["task_plan", "delegation_record"],
          "can_delegate": true,
          "can_verify": true,
          "can_modify_artifacts": true,
          "can_request_approval": true,
          "max_budget_scope": "session",
          "delegation_boundaries": "may delegate to specialist, reviewer, and verifier roles only; must not delegate to unverified roles"
        },
        "constraint_profile": {
          "constraint_profile_id": "con-mgr-001",
          "role_id": "role-mgr-001",
          "forbidden_tools": ["execute_remote", "delete_production"],
          "forbidden_actions": ["direct_code_write"],
          "approval_required_actions": ["deploy", "modify_production_config"],
          "must_not_write_without_verification": true,
          "must_not_delegate_further": false,
          "sensitive_data_restrictions": "must not expose credentials in delegation context"
        },
        "prompt_profile": {
          "prompt_profile_id": "prompt-mgr-001",
          "role_id": "role-mgr-001",
          "system_prompt_ref": "prompts/manager_system_v2.md",
          "prompt_fragments": ["fragments/delegation_guidelines", "fragments/review_criteria"],
          "instruction_pack_refs": ["packs/coordination_protocol"],
          "style_notes": "Direct, action-oriented, focused on task structure",
          "handoff_template_ref": "templates/manager_handoff.md"
        },
        "evaluation_profile": {
          "evaluation_profile_id": "eval-mgr-001",
          "role_id": "role-mgr-001",
          "success_criteria": ["all subtasks completed", "delegation decisions are correct", "no resource conflicts"],
          "failure_modes": ["over-delegation", "lost context between delegates", "unbalanced work distribution"],
          "required_evidence_types": ["delegation_log", "task_completion_report"],
          "quality_metrics": ["completion_rate", "delegation_accuracy", "cycle_time"],
          "review_policy": "post_run_review"
        }
      }
    },
