{
  "examples": [
    {
      "name": "Coding benchmark suite",
      "description": "A suite of 3 coding tasks for measuring harness correctness and latency.",
      "suite": {
        "suite_id": "code-bench-v1",
        "name": "Code Generation Benchmarks v1",
        "tasks": [
          {
            "task_id": "task-add",
            "name": "Add two numbers",
            "task_type": "coding",
            "prompt": "Write a Python function that takes two integers and returns their sum.",
            "inputs": {"a": 3, "b": 5},
            "reference": {
              "reference_id": "ref-add",
              "description": "Function returns correct sum",
              "expected_artifacts": ["solution.py"],
              "reference_notes": "Handle negative numbers"
            },
            "tags": ["math", "basic"]
          },
          {
            "task_id": "task-parse-json",
            "name": "Parse JSON string",
            "task_type": "coding",
            "prompt": "Write a Python function that parses a JSON string and returns the 'name' field.",
            "inputs": {"json_str": "{\"name\": \"Alice\", \"age\": 30}"},
            "reference": {
              "reference_id": "ref-parse",
              "description": "Returns 'Alice' from the JSON",
              "expected_artifacts": ["solution.py"]
            },
            "tags": ["json", "parsing"]
          },
          {
            "task_id": "task-sort-list",
            "name": "Sort a list",
            "task_type": "coding",
            "prompt": "Write a Python function that sorts a list of integers in ascending order.",
            "inputs": {"items": [3, 1, 4, 1, 5]},
            "reference": {
              "reference_id": "ref-sort",
              "description": "Returns sorted list [1, 1, 3, 4, 5]",
              "expected_artifacts": ["solution.py"]
            },
            "tags": ["sorting", "basic"]
          }
        ]
      }
    },
    {
      "name": "Debugging benchmark task with deterministic grader",
      "description": "A debugging task that asks the agent to fix a null pointer crash. Graded by deterministic output matching.",
      "task": {
        "task_id": "task-debug-null",
        "name": "Fix null pointer crash",
        "task_type": "debugging",
        "prompt": "Fix the null pointer dereference in the following code:\n\n```python\ndef get_name(user):\n    return user['name']\n```",
        "inputs": {"code": "def get_name(user):\n    return user['name']"},
        "reference": {
          "reference_id": "ref-debug-null",
          "description": "Added None/fallback check before accessing key",
          "expected_artifacts": ["fixed.py"],
          "reference_notes": "Use .get() or check for None"
        },
        "tags": ["null-safety", "debugging"]
      },
      "graders": [
        {
          "grader_id": "grd-deterministic",
          "name": "Output matches expected fix",
          "grader_type": "deterministic",
          "rubric": "Solution must handle None input without raising TypeError",
          "pass_condition": "output == expected_fixed_output"
        }
      ]
    },
